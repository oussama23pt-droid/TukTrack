<manifest xmlns:android="http://schemas.android.com/apk/res/android">
<!--  ── Internet ──  -->
<uses-permission android:name="android.permission.INTERNET"/>
<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
<!--  ── Location — foreground AND background ──
         ACCESS_BACKGROUND_LOCATION is what enables the "Allow all the time"
         option to appear in the Location permission screen.
         It MUST be present AND targetSdk must be <= 29 OR the app must have
         already been granted ACCESS_FINE_LOCATION before requesting it.  -->
<uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
<uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
<uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>
<!--  ── Foreground service for persistent location ──  -->
<uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
<uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>
<!--  ── Persistent status-bar notification (required Android 13 / API 33+) ──  -->
<uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
<!--  ── Keep CPU alive while tracking ──  -->
<uses-permission android:name="android.permission.WAKE_LOCK"/>
<!--  ── SYSTEM_ALERT_WINDOW = "Display over other apps"
         This is what makes TukTrack appear in the system list at:
         Settings → Apps → Special app access → Display over other apps.
         Without this declaration the app is invisible to that list. ──  -->
<uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
<!--  ── Restart tracking after phone reboot ──  -->
<uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
<!--  ── Vibration for SOS ──  -->
<uses-permission android:name="android.permission.VIBRATE"/>
<application android:allowBackup="true" android:icon="@mipmap/ic_launcher" android:label="@string/app_name" android:roundIcon="@mipmap/ic_launcher_round" android:supportsRtl="true" android:theme="@style/AppTheme" android:usesCleartextTraffic="true" android:hardwareAccelerated="true">
<activity android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode" android:name=".MainActivity" android:label="@string/title_activity_main" android:theme="@style/AppTheme.NoActionBarLaunch" android:launchMode="singleTask" android:exported="true" android:showOnLockScreen="true">
<intent-filter>
<action android:name="android.intent.action.MAIN"/>
<category android:name="android.intent.category.LAUNCHER"/>
</intent-filter>
</activity>
<!--  ── Background location foreground services (transistorsoft) ──  -->
<service android:name="com.transistorsoft.locationmanager.service.TrackingService" android:foregroundServiceType="location" android:exported="false"/>
<service android:name="com.transistorsoft.locationmanager.service.LocationRequestService" android:foregroundServiceType="location" android:exported="false"/>
<!--  ── Boot receiver — restarts tracking after reboot ──  -->
<receiver android:name="com.transistorsoft.locationmanager.util.BootReceiver" android:exported="false">
<intent-filter>
<action android:name="android.intent.action.BOOT_COMPLETED"/>
</intent-filter>
</receiver>
<!--  ── @capacitor/local-notifications channel config ──  -->
<meta-data android:name="com.capacitorjs.plugins.localnotifications.default_channel_id" android:value="tuktrack_foreground"/>
<meta-data android:name="com.capacitorjs.plugins.localnotifications.default_channel_name" android:value="TukTrack Serviço Ativo"/>
<meta-data android:name="com.capacitorjs.plugins.localnotifications.default_channel_importance" android:value="4"/>
<provider android:name="androidx.core.content.FileProvider" android:authorities="${applicationId}.fileprovider" android:exported="false" android:grantUriPermissions="true">
<meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths"/>
</provider>
</application>
</manifest>
